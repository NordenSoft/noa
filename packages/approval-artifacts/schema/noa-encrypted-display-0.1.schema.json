{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://noatrust.com/schema/noa-encrypted-display-0.1.schema.json",
  "title": "NOA Encrypted Display",
  "description": "The HPKE-AEAD ciphertext of the human-readable approval display (D15-v2, §9). NOT Ed25519-signed — integrity comes from the AEAD tag + AAD binding + the displayCiphertextHash the gate signs INSIDE the Hold Envelope over this WHOLE object (F2). One canonical multi-device shape: a single display blob under a random CEK, HPKE-wrapped per registered device in recipients[]. There is NO singular recipientKid. Alpha (F20) uses recipients.length==1.",
  "type": "object",
  "additionalProperties": false,
  "required": ["spec", "tenant", "holdId", "deferredReceiptHash", "expiresAt", "suite", "payload", "recipients", "aadHash"],
  "properties": {
    "spec": { "const": "noa.encrypted-display/0.1" },
    "tenant": { "type": "string", "pattern": "^.{1,256}$" },
    "holdId": { "type": "string", "pattern": "^.{1,128}$" },
    "deferredReceiptHash": { "$ref": "#/$defs/hash256" },
    "expiresAt": { "$ref": "#/$defs/rfc3339" },
    "suite": { "$ref": "#/$defs/suite" },
    "payload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["nonce", "ciphertext"],
      "properties": {
        "nonce": { "type": "string", "pattern": "^.{1,256}$" },
        "ciphertext": { "type": "string", "pattern": "^.{1,65536}$" }
      }
    },
    "recipients": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["kid", "enc", "wrappedCek"],
        "properties": {
          "kid": { "type": "string", "pattern": "^.{1,128}$" },
          "enc": { "type": "string", "pattern": "^.{1,2048}$" },
          "wrappedCek": { "type": "string", "pattern": "^.{1,2048}$" }
        }
      }
    },
    "aadHash": { "$ref": "#/$defs/hash256" }
  },
  "$defs": {
    "hash256": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "rfc3339": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}[Tt]\\d{2}:\\d{2}:\\d{2}(\\.\\d{1,9})?([Zz]|[+-]\\d{2}:\\d{2})$"
    },
    "suite": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kem", "kdf", "aead"],
      "properties": {
        "kem": { "const": 32 },
        "kdf": { "const": 1 },
        "aead": { "enum": [2, 3] }
      }
    }
  }
}
