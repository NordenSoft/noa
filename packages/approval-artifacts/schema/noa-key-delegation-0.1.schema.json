{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://noatrust.com/schema/noa-key-delegation-0.1.schema.json",
  "title": "NOA Manifest-Signer Delegation",
  "description": "Offline Tenant Root Authority-signed delegation (D16-v2, §9): grants a delegated key the key-manifest-sign permission. Domain NOA-KeyDelegation-v0.1-sig. Signed by the tenant root (e.g. tenant-authority-1), never the gate. Alpha requires ≥1 static root-signed delegation (F11/F21).",
  "type": "object",
  "additionalProperties": false,
  "required": ["spec", "tenant", "delegatedKid", "delegatedPublicKey", "permissions", "validFrom", "expiresAt", "sig"],
  "properties": {
    "spec": { "const": "noa.key-delegation/0.1" },
    "tenant": { "type": "string", "pattern": "^.{1,256}$" },
    "delegatedKid": { "type": "string", "pattern": "^.{1,128}$" },
    "delegatedPublicKey": { "type": "string", "pattern": "^.{1,1024}$" },
    "permissions": {
      "type": "array",
      "minItems": 1,
      "items": { "enum": ["key-manifest-sign"] }
    },
    "validFrom": { "$ref": "#/$defs/rfc3339" },
    "expiresAt": { "$ref": "#/$defs/rfc3339" },
    "sig": { "$ref": "#/$defs/sig" }
  },
  "$defs": {
    "rfc3339": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}[Tt]\\d{2}:\\d{2}:\\d{2}(\\.\\d{1,9})?([Zz]|[+-]\\d{2}:\\d{2})$"
    },
    "sig": {
      "type": "object",
      "additionalProperties": false,
      "required": ["alg", "kid", "value"],
      "properties": {
        "alg": { "const": "ed25519" },
        "kid": { "type": "string", "pattern": "^.{1,128}$" },
        "value": { "type": "string", "pattern": "^.{1,512}$" }
      }
    }
  }
}
