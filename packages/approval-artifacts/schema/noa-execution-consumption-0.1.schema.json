{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://noatrust.com/schema/noa-execution-consumption-0.1.schema.json",
  "title": "NOA Execution Consumption (post-execution)",
  "description": "The gate's post-execution proof binding the grant (by refHash) to the attempt receipt (D13/D18, §8). Domain NOA-ExecConsume-v0.1-sig. Signer TYPE+ROLE = GATE + execution-signer (F15).",
  "type": "object",
  "additionalProperties": false,
  "required": ["spec", "grantHash", "consumedAt", "attemptReceiptHash", "result", "sig"],
  "properties": {
    "spec": { "const": "noa.execution-consumption/0.1" },
    "grantHash": { "$ref": "#/$defs/hash256" },
    "consumedAt": { "$ref": "#/$defs/rfc3339" },
    "attemptReceiptHash": { "$ref": "#/$defs/hash256" },
    "result": { "enum": ["DISPATCHED", "FAILED_BEFORE_DISPATCH"] },
    "sig": { "$ref": "#/$defs/sig" }
  },
  "$defs": {
    "hash256": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "rfc3339": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}[Tt]\\d{2}:\\d{2}:\\d{2}(\\.\\d{1,9})?([Zz]|[+-]\\d{2}:\\d{2})$"
    },
    "sig": {
      "type": "object",
      "additionalProperties": false,
      "required": ["alg", "kid", "value"],
      "properties": {
        "alg": { "const": "ed25519" },
        "kid": { "type": "string", "pattern": "^.{1,128}$" },
        "value": { "type": "string", "pattern": "^.{1,512}$" }
      }
    }
  }
}
